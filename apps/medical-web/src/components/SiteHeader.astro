---
import { clinicSite, primaryNav } from "../data/site";

const { activeHref = "/" } = Astro.props;
const navItems = primaryNav.filter((item) => item.href !== "/");
---

<div class="topbar">
  <span><i class="bi bi-telephone"></i> Hotline: {clinicSite.hotline}</span>
  <span><i class="bi bi-clock"></i> {clinicSite.hours}</span>
  <span><i class="bi bi-geo-alt"></i> {clinicSite.address}</span>
</div>

<header class="site-header">
  <a class="brand brand-image" href="/" aria-label={clinicSite.name}>
    <img src={clinicSite.logoImage} alt="" />
  </a>

  <nav class="site-nav" aria-label="Chính">
    {navItems.map((item) => (
      <a class:list={{ "is-active": activeHref === item.href }} href={item.href}>
        {item.label}
      </a>
    ))}
  </nav>

  <button class="nav-toggle" type="button" data-nav-toggle aria-expanded="false" aria-label="Mở menu">
    <i class="bi bi-list"></i>
    <span>Menu</span>
  </button>

  <button class="nav-cta" type="button" data-open-contact-dialog>
    <i class="bi bi-calendar2-check"></i>
    <span>Đặt lịch tư vấn</span>
  </button>
</header>
