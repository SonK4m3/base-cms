---
const {
  title = "Base CMS",
  description = "Medical CMS and SEO content platform",
  canonical,
  noindex = false,
  ogType = "website",
  structuredData
} = Astro.props;

const canonicalUrl = canonical ?? Astro.site?.href ?? null;
---
<title>{title}</title>
<meta name="description" content={description} />
{noindex ? <meta name="robots" content="noindex,nofollow" /> : null}
{canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta name="theme-color" content="#0f7f89" />
{structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData]).map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))
  : null}
