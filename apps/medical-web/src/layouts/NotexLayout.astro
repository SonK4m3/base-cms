---
import SeoHead from "../components/SeoHead.astro";
import { notexSite } from "../data/notex";
import "../styles/notex.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: "website" | "article" | "profile";
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, canonical, noindex = false, ogType = "website", structuredData }: Props = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) => href === "/" ? path === "/" : path.startsWith(href);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      ogType={ogType}
      structuredData={structuredData}
      siteName={notexSite.name}
      siteDescription={notexSite.description}
      lang={notexSite.locale}
      themeColor="#0d0d0f"
    />
  </head>
  <body class="notex-body">
    <header class="notex-header">
      <a class="notex-logo" href="/" aria-label="Notex home"><span class="notex-logo-mark">N</span><span>notex</span></a>
      <nav class="notex-nav" aria-label="Main navigation">
        {notexSite.navigation.map((item) => <a class:list={{ active: isActive(item.href) }} href={item.href}>{item.label}</a>)}
      </nav>
      <div class="notex-header-actions"><a class="notex-login" href="/about/">Sign in</a><a class="notex-button notex-button-small" href="/pricing/">Start free</a></div>
      <button class="notex-menu-button" type="button" aria-expanded="false" aria-controls="notex-mobile-nav" data-notex-menu>Menu</button>
    </header>
    <nav id="notex-mobile-nav" class="notex-mobile-nav" aria-label="Mobile navigation" hidden>
      {notexSite.navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/about/">Sign in</a><a class="notex-button" href="/pricing/">Start free</a>
    </nav>
    <main><slot /></main>
    <footer class="notex-footer">
      <div class="notex-footer-top"><div><a class="notex-logo" href="/"><span class="notex-logo-mark">N</span><span>notex</span></a><p class="notex-footer-blurb">The context layer for meetings, audio, and documents.</p></div><div class="notex-footer-links"><div><strong>Product</strong><a href="/features/">Features</a><a href="/pricing/">Pricing</a><a href="/integrations/">Integrations</a><a href="/docs/">Docs</a></div><div><strong>Learn</strong><a href="/use-cases/">Use cases</a><a href="/compare/">Comparisons</a><a href="/customers/">Customers</a><a href="/blog/">Blog</a></div><div><strong>Company</strong><a href="/about/">About</a><a href="mailto:hello@notex.example">Contact</a><a href="/chinh-sach-bao-mat/">Privacy</a><a href="/chinh-sach-bien-tap/">Terms</a></div></div></div>
      <div class="notex-footer-bottom"><span>© 2026 Notex. Built for useful context.</span><span>Made for teams that think in conversations.</span></div>
    </footer>
    <script is:inline>
      const menu = document.querySelector("[data-notex-menu]");
      const mobileNav = document.querySelector("#notex-mobile-nav");
      if (menu instanceof HTMLButtonElement && mobileNav instanceof HTMLElement) {
        menu.addEventListener("click", () => {
          const open = menu.getAttribute("aria-expanded") === "true";
          menu.setAttribute("aria-expanded", String(!open));
          mobileNav.hidden = open;
        });
      }
    </script>
  </body>
</html>
