---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  siteName: string;
  siteLogo?: string;
  lang?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: "website" | "article" | "profile";
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
}

const {
  title,
  description,
  siteName,
  siteLogo,
  lang = "en",
  canonical,
  noindex = false,
  ogType = "website",
  structuredData,
  image,
  imageWidth,
  imageHeight
}: Props = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  ogType={ogType}
  structuredData={structuredData}
  siteName={siteName}
  siteDescription={description}
  siteLogo={siteLogo}
  lang={lang}
  image={image}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
>
  <main class="page-shell">
    <slot />
  </main>
</BaseLayout>
