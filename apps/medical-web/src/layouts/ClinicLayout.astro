---
import BaseLayout from "./BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { clinicSite } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: "website" | "article" | "profile";
  activeHref?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
}

const {
  title = "Phòng khám Tạo An Tâm",
  description = "Website phòng khám tế bào gốc và y học tái tạo",
  canonical,
  noindex,
  ogType,
  activeHref = "/",
  structuredData,
  image,
  imageWidth,
  imageHeight
}: Props = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  ogType={ogType}
  structuredData={structuredData}
  siteName={clinicSite.name}
  siteDescription={description}
  siteLogo={clinicSite.logoImage}
  lang="vi"
  image={image}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
>
  <SiteHeader activeHref={activeHref} />
  <main class="page-shell">
    <slot />
  </main>
  <SiteFooter />
</BaseLayout>
