---
import NotexLayout from "../layouts/NotexLayout.astro";
import { notexFeatures, notexFaq, notexSite, notexUseCases } from "../data/notex";
import { createBreadcrumbSchema } from "@base-cms/site-core";

const softwareSchema = {
  "@type": "SoftwareApplication",
  name: notexSite.name,
  url: notexSite.url,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, Chrome, Windows, macOS",
  description: notexSite.description,
  featureList: notexFeatures.map((feature) => feature.title),
  publisher: { "@type": "Organization", name: notexSite.name }
};
const faqSchema = { "@type": "FAQPage", mainEntity: notexFaq.map((item) => ({ "@type": "Question", name: item.question, acceptedAnswer: { "@type": "Answer", text: item.answer } })) };
const breadcrumbs = createBreadcrumbSchema([{ name: "Notex", url: `${notexSite.url}/` }]);
---
<NotexLayout title="Notex — AI notes for meetings, audio, and documents" description={notexSite.description} structuredData={[softwareSchema, faqSchema, breadcrumbs]}>
  <section class="notex-hero">
    <div class="notex-hero-copy">
      <p class="notex-eyebrow">The context layer for modern teams</p>
      <h1>Turn conversations into clear next steps.</h1>
      <p class="notex-lede">Notex is an AI note-taking platform for recording meetings, creating transcripts, summarizing documents, and turning discussions into work — without a meeting bot.</p>
      <div class="notex-actions"><a class="notex-button" href="/pricing/">Start free</a><a class="notex-button notex-button-light" href="/features/">See how it works</a></div>
      <p class="notex-proof">For sales teams, researchers, operators, and anyone whose work happens in conversations.</p>
    </div>
    <div class="notex-hero-art" aria-label="Notex meeting notes preview">
      <div class="notex-window-top"><i></i><i></i><i></i><span class="notex-window-label">Notex / weekly product review</span></div>
      <div class="notex-note"><span class="notex-note-label">AI summary</span><h3>Three decisions. Four owners. One clear follow-up.</h3><div class="notex-note-row"><strong>Decision</strong>Ship the browser capture beta to the design partner group.</div><div class="notex-note-row"><strong>Action item</strong>Maya to share the onboarding checklist by Friday.</div><div class="notex-note-row"><strong>Open question</strong>Which workspace should own the integration roadmap?</div></div>
    </div>
  </section>

  <section class="notex-section notex-section-dark"><div class="notex-container"><div class="notex-section-head"><div><p class="notex-eyebrow">One workflow, less recovery</p><h2>Everything you need after the conversation.</h2></div><p class="notex-section-intro">Notex helps you capture the source, understand what happened, and move the useful parts into the tools where work gets done.</p></div><div class="notex-feature-grid">{notexFeatures.map((feature, index) => <a class="notex-card" href={`/features/${feature.slug}/`}><span class="notex-card-number">0{index + 1}</span><h3>{feature.title}</h3><p>{feature.description}</p><span class="notex-arrow">↗</span></a>)}</div></div></section>

  <section class="notex-section"><div class="notex-container"><div class="notex-prompt"><blockquote>“What AI tool can summarize a meeting without adding a bot?”<cite>A real question Notex is built to answer</cite></blockquote><div><p>Notex captures audio from the user's browser session or accepts a local file. That means your team can create a transcript and summary without adding another participant to Google Meet or Zoom.</p><a class="notex-button notex-button-light" href="/compare/meeting-bot/">Compare the workflow →</a></div></div></div></section>

  <section class="notex-section notex-section-blue"><div class="notex-container"><div class="notex-section-head"><div><p class="notex-eyebrow">Built around real questions</p><h2>Start with the situation, not the keyword.</h2></div><p class="notex-section-intro">Explore focused workflows for the people who need to remember, explain, and act on what was said.</p></div><div class="notex-index-grid">{notexUseCases.slice(0, 3).map((item) => <a class="notex-index-card" href={`/use-cases/${item.slug}/`}><span>{item.label}</span><h3>{item.title}</h3><p>{item.description}</p></a>)}</div></div></section>

  <section class="notex-section"><div class="notex-container"><div class="notex-section-head"><div><p class="notex-eyebrow">Useful context, visible evidence</p><h2>Summaries should be easy to verify.</h2></div><p class="notex-section-intro">Every output should help a person understand what happened, where it came from, and what to do next.</p></div><div class="notex-detail-grid"><div><h2>Capture → understand → act</h2><p class="notex-lede">Notex keeps the original transcript or document close to the summary, so a concise answer never has to become a black box.</p><a class="notex-button" href="/docs/">Read the workflow docs</a></div><ul class="notex-list"><li><strong>Capture the source.</strong><br />Record from the browser or upload the file you already have.</li><li><strong>Ask a useful question.</strong><br />Summarize, find risks, compare viewpoints, or extract decisions.</li><li><strong>Move the work forward.</strong><br />Edit and share tasks, notes, and decisions with the people who need them.</li></ul></div></div></section>
</NotexLayout>
