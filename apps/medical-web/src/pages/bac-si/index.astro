---
import ClinicLayout from "../../layouts/ClinicLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { doctors, clinicSite, articleCards, faqItems } from "../../data/site";
import "../../styles/global.css";

const heroImage = "/assets/hero-tao-an-tam.png";

const standards = [
  {
    title: "Bằng cấp rõ ràng",
    description: "Thông tin học vị, chứng chỉ và phạm vi phụ trách được trình bày minh bạch trên từng hồ sơ."
  },
  {
    title: "Chứng chỉ hành nghề",
    description: "Nội dung hồ sơ bác sĩ được xây theo hướng củng cố trust và chuẩn hóa thông tin chuyên môn."
  },
  {
    title: "Kinh nghiệm lâm sàng",
    description: "Không chỉ nêu số năm kinh nghiệm mà còn nêu thế mạnh đánh giá, tư vấn và theo dõi."
  },
  {
    title: "Cập nhật kiến thức",
    description: "Nhấn vào các hoạt động đào tạo, cập nhật y khoa và vai trò trong biên tập nội dung."
  }
];

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Trang chủ", item: "https://taitaoantam.vn/" },
    { "@type": "ListItem", position: 2, name: "Đội ngũ bác sĩ", item: "https://taitaoantam.vn/bac-si/" }
  ]
};

const doctorsStructuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Đội ngũ bác sĩ",
  itemListElement: doctors.map((doctor, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: doctor.name,
    url: `https://taitaoantam.vn/bac-si/${doctor.slug}/`
  }))
};
---

<ClinicLayout
  title={`${clinicSite.name} | Đội ngũ bác sĩ`}
  description="Danh sách bác sĩ, chuyên môn và hồ sơ từng bác sĩ"
  activeHref="/bac-si"
  structuredData={[breadcrumbStructuredData, doctorsStructuredData]}
>
  <section class="page-hero page-hero-slim doctor-hero">
    <div class="hero-copy">
      <p class="eyebrow">Đội ngũ bác sĩ / chuyên gia</p>
      <h1>Đội ngũ bác sĩ và chuyên gia</h1>
      <p class="hero-text">
        Trang bác sĩ không chỉ để giới thiệu đội ngũ, mà còn là trụ cột authority cho toàn website. Mỗi hồ sơ được trình bày theo hướng
        giúp người đọc, Google và AI hiểu rõ ai chịu trách nhiệm chuyên môn cho nội dung và quá trình tư vấn.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/lien-he">Đặt lịch tư vấn</a>
        <a class="button button-secondary" href="#ho-so">Xem hồ sơ</a>
      </div>
      <div class="hero-proof-grid">
        <div class="hero-proof-item">Có học vị, thế mạnh và vai trò rõ ràng</div>
        <div class="hero-proof-item">Có nguyên tắc tư vấn và định hướng chuyên môn</div>
        <div class="hero-proof-item">Có liên kết nội bộ tới FAQ, blog và phương pháp</div>
        <div class="hero-proof-item">Phù hợp để xây trust và author entity</div>
      </div>
    </div>

    <div class="hero-visual hero-visual-large doctor-hero-image">
      <img src={heroImage} alt="Không gian tư vấn tại Phòng khám Tái Tạo An Tâm" />
    </div>
  </section>

  <section class="section-block" id="ho-so">
    <SectionHeading eyebrow="Hồ sơ đội ngũ" title="Đội ngũ bác sĩ / chuyên gia" />
    <div class="doctor-grid doctor-showcase-grid">
      {doctors.map((doctor) => (
        <article class="doctor-card doctor-card-profile">
          <img src={doctor.image} alt={doctor.name} class="doctor-photo doctor-photo-profile" />
          <div class="doctor-profile-copy">
            <p class="doctor-eyebrow">{doctor.title}</p>
            <h3>{doctor.name}</h3>
            <p class="doctor-credential">{doctor.credentialLine}</p>
            <p class="doctor-meta">{doctor.experience}</p>
            <p>{doctor.seoSummary}</p>
            <p class="article-credit">Chuyên môn: {doctor.specialty} · Số CCHN: {doctor.licenseId}</p>
          </div>
          <div class="inline-tags doctor-tags">
            {doctor.expertise.slice(0, 3).map((item) => <span class="chip">{item}</span>)}
          </div>
          <a class="doctor-link" href={`/bac-si/${doctor.slug}`}>Xem hồ sơ</a>
          <a class="button button-secondary doctor-secondary" href="/lien-he">Đặt lịch tư vấn</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Tiêu chuẩn chuyên môn" title="Tiêu chuẩn đội ngũ chuyên môn" />
    <div class="card-grid standards-grid">
      {standards.map((item) => (
        <article class="info-card info-card-center">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="split-grid">
    <article class="section-block">
      <SectionHeading eyebrow="Nội dung hỗ trợ" title="Blog và FAQ nên nối với đội ngũ bác sĩ" />
      <div class="faq-list">
        {articleCards.map((article) => (
          <article class="faq-item">
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <a class="button button-secondary" href={`/blog/${article.slug}`}>Đọc bài viết</a>
          </article>
        ))}
      </div>
    </article>

    <article class="section-block">
      <SectionHeading eyebrow="Câu hỏi liên quan" title="Câu hỏi thường gặp nên gắn với bác sĩ" />
      <div class="faq-list">
        {faqItems.slice(0, 4).map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.shortAnswer}</p>
          </details>
        ))}
      </div>
    </article>
  </section>

  <section class="doctor-cta">
    <div class="doctor-cta-copy">
      <p class="eyebrow">Chọn bác sĩ phù hợp</p>
      <h2>Bắt đầu hành trình tư vấn của bạn với đúng chuyên môn</h2>
      <p>
        Đặt lịch để đội ngũ tiếp nhận sàng lọc hồ sơ ban đầu, sau đó điều phối đến bác sĩ có thế mạnh phù hợp với nhu cầu tư vấn của bạn.
      </p>
      <div class="cta-benefits doctor-cta-benefits">
        <div>Tư vấn 1:1</div>
        <div>Định hướng rõ ràng</div>
        <div>Bảo mật thông tin</div>
      </div>
    </div>
    <div class="doctor-cta-panel">
      <img src="/assets/contact-cta-portrait.png" alt="Bác sĩ tư vấn" />
      <div class="doctor-cta-actions">
        <a class="button button-primary" href="tel:1900123456">1900 1234 56</a>
        <a class="button button-secondary" href="/lien-he">Đặt lịch tư vấn ngay</a>
      </div>
    </div>
  </section>
</ClinicLayout>
