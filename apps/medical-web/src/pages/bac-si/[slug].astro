---
export function getStaticPaths() {
  return [
    { params: { slug: "nguyen-minh-tuan" } },
    { params: { slug: "tran-thu-hang" } },
    { params: { slug: "le-quang-huy" } }
  ];
}

import ClinicLayout from "../../layouts/ClinicLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { doctors, clinicSite } from "../../data/site";
import "../../styles/global.css";

const doctor = doctors.find((item) => item.slug === Astro.params.slug);
if (!doctor) {
  throw new Error(`Doctor not found: ${Astro.params.slug}`);
}

const physicianStructuredData = {
  "@context": "https://schema.org",
  "@type": "Physician",
  name: doctor.name,
  description: doctor.bio,
  medicalSpecialty: doctor.specialty,
  hospitalAffiliation: {
    "@type": "MedicalClinic",
    name: clinicSite.name
  }
};
---

<ClinicLayout
  title={`${doctor.name} | Hồ sơ bác sĩ`}
  description={doctor.bio}
  activeHref="/bac-si"
  structuredData={physicianStructuredData}
>
  <section class="profile-hero section-block">
    <div class="profile-image">
      <img src={doctor.image} alt={doctor.name} />
    </div>
    <div class="profile-summary">
      <p class="eyebrow">Hồ sơ bác sĩ</p>
      <h1>{doctor.name}</h1>
      <p class="profile-role">{doctor.title}</p>
      <p class="profile-credential">{doctor.credentialLine}</p>
      <p>{doctor.role}</p>
      <p>{doctor.bio}</p>
      <div class="profile-meta-grid">
        <div><strong>{doctor.experience}</strong></div>
        <div><strong>Số CCHN:</strong> {doctor.licenseId}</div>
        <div><strong>Vai trò:</strong> Duyệt nội dung / tư vấn chuyên môn</div>
      </div>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Chuyên môn" title="Lĩnh vực phụ trách và thế mạnh" />
    <div class="inline-tags">
      {doctor.expertise.map((item) => <span class="chip">{item}</span>)}
    </div>
    <article class="page-card">
      <p><strong>Chuyên khoa trọng tâm:</strong> {doctor.specialty}</p>
      <p><strong>Trọng tâm hồ sơ công khai:</strong> {doctor.profileFocus}</p>
    </article>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Định hướng chuyên môn" title="Nguyên tắc tư vấn" />
    <article class="page-card">
      <p>{doctor.authorityNote}</p>
    </article>
  </section>

  <section class="section-block split-page">
    <article class="page-card">
      <h2>Quá trình đào tạo</h2>
      <ul class="info-list">
        {doctor.education.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article class="page-card">
      <h2>Điểm nhấn trong tư vấn</h2>
      <ul class="info-list">
        {doctor.highlights.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="section-block split-page">
    <article class="page-card">
      <h2>Trọng tâm phụ trách</h2>
      <ul class="info-list">
        {doctor.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article class="page-card">
      <h2>Chứng chỉ và cập nhật chuyên môn</h2>
      <ul class="info-list">
        {doctor.certifications.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Vai trò authority" title="Các chủ đề bác sĩ tham gia duyệt nội dung" />
    <ul class="info-list">
      {doctor.reviewedTopics.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</ClinicLayout>
