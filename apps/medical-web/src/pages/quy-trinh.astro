---
import ClinicLayout from "../layouts/ClinicLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { clinicSite, processSteps } from "../data/site";
import "../styles/global.css";
---

<ClinicLayout title={`${clinicSite.name} | Quy trình`} description="Quy trình tư vấn và thăm khám" activeHref="/quy-trinh">
  <section class="page-hero page-hero-slim">
    <div class="hero-copy">
      <p class="eyebrow">Quy trình tư vấn – thăm khám</p>
      <h1>Mô tả rõ từng bước từ đặt lịch, sàng lọc, khám, đánh giá, tư vấn và theo dõi.</h1>
      <p class="hero-text">
        Trang quy trình giúp khách hàng biết trước điều gì sẽ xảy ra, giảm lo lắng và làm rõ trách nhiệm của từng bước.
      </p>
    </div>
    <div class="hero-visual hero-visual-note">
      <h2>6 bước chính</h2>
      <ol>
        {processSteps.map((step) => <li>{step.title}</li>)}
      </ol>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Các bước" title="Quy trình chuẩn cho bản đầu" />
    <div class="process-grid process-grid-full">
      {processSteps.map((step, index) => (
        <article class="process-card">
          <div class="step-number">{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>
</ClinicLayout>
