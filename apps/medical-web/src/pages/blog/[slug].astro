---
import NotexLayout from "../../layouts/NotexLayout.astro";
import { notexBlog, notexSite } from "../../data/notex";
import { createBreadcrumbSchema } from "@base-cms/site-core";
export function getStaticPaths() { return notexBlog.map((post) => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props;
const articleSchema = { "@type": "Article", headline: post.title, description: post.description, datePublished: post.date, author: { "@type": "Organization", name: notexSite.name }, publisher: { "@type": "Organization", name: notexSite.name } };
const breadcrumbs = createBreadcrumbSchema([{ name: "Notex", url: notexSite.url }, { name: "Blog", url: `${notexSite.url}blog/` }, { name: post.title, url: `${notexSite.url}blog/${post.slug}/` }]);
---
<NotexLayout title={`${post.title} | Notex`} description={post.description} canonical={`/blog/${post.slug}/`} ogType="article" structuredData={[articleSchema, breadcrumbs]}>
  <article class="notex-page-hero"><div class="notex-container"><p class="notex-breadcrumb"><a href="/blog/">Blog</a> / {post.category}</p><p class="notex-eyebrow">{post.category} · {post.date} · {post.readTime}</p><h1>{post.title}</h1><p>{post.description}</p></div></article>
  <section class="notex-section"><div class="notex-container"><div class="notex-detail-grid"><div><h2>The short answer</h2><div class="notex-answer">The best AI note-taking workflow starts with a real source, answers a specific question, and keeps the resulting action close to the evidence.</div><p class="notex-lede">This article is part of the Notex editorial series. It is designed to be useful on its own, with concrete examples and clear trade-offs rather than generic AI promises.</p></div><aside><h2>Keep exploring</h2><ul class="notex-list"><li><a href="/features/meeting-notes/">Meeting notes</a></li><li><a href="/use-cases/sales-teams/">Sales workflows</a></li><li><a href="/compare/meeting-bot/">Meeting bot comparison</a></li></ul></aside></div></div></section>
</NotexLayout>
