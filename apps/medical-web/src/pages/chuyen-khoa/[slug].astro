---
import ClinicLayout from "../../layouts/ClinicLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { articleCards, clinicSite, doctors, faqItems } from "../../data/site";
import { specialtyPages } from "../../data/seo";
import "../../styles/global.css";

export function getStaticPaths() {
  return specialtyPages.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const doctor = doctors.find((entry) => entry.slug === item.doctorSlug);
const article = articleCards.find((entry) => entry.slug === item.articleSlug);
const faq = faqItems.find((entry) => entry.slug === item.faqSlug);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: "https://taitaoantam.vn/" },
      { "@type": "ListItem", position: 2, name: "Chuyên khoa", item: "https://taitaoantam.vn/chuyen-khoa/" },
      { "@type": "ListItem", position: 3, name: item.title, item: `https://taitaoantam.vn/chuyen-khoa/${item.slug}/` }
    ]
  }
];
---

<ClinicLayout
  title={`${item.title} | Chuyên khoa`}
  description={item.description}
  canonical={`/chuyen-khoa/${item.slug}/`}
  structuredData={structuredData}
  activeHref="/bac-si"
>
  <section class="article-hero">
    <div>
      <p class="eyebrow">Chuyên khoa / {item.keyword}</p>
      <h1>{item.title}</h1>
      <p>{item.description}</p>
      <div class="inline-tags">
        <span class="tag-pill">{item.keyword}</span>
        {doctor ? <span class="tag-pill">Bác sĩ: {doctor.name}</span> : null}
        {article ? <span class="tag-pill">Bài viết: {article.title}</span> : null}
      </div>
    </div>
    <article class="page-card article-body">
      <SectionHeading eyebrow="Tổng quan" title="Nội dung trang này giúp gì cho người đọc?" />
      <p>{item.overview}</p>
      <ul class="mini-list">
        {item.angles.map((angle) => <li>{angle}</li>)}
      </ul>
    </article>
  </section>

  <section class="split-grid">
    <article class="section-block">
      <SectionHeading eyebrow="Bác sĩ phụ trách" title="Hồ sơ chuyên gia liên quan" />
      {doctor ? (
        <article class="doctor-card doctor-card-inline">
          <img src={doctor.image} alt={doctor.name} />
          <div>
            <p class="doctor-eyebrow">{doctor.title}</p>
            <h3>{doctor.name}</h3>
            <p>{doctor.profileFocus}</p>
            <p class="doctor-credential">{doctor.specialty}</p>
          </div>
          <a class="button button-primary" href={`/bac-si/${doctor.slug}`}>Xem hồ sơ</a>
        </article>
      ) : null}
    </article>

    <article class="section-block">
      <SectionHeading eyebrow="Tiếp tục đọc" title="Trang nên mở tiếp" />
      <div class="faq-list">
        {article ? (
          <article class="faq-item">
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <a class="button button-secondary" href={`/blog/${article.slug}`}>Đọc bài viết liên quan</a>
          </article>
        ) : null}
        {faq ? (
          <details class="faq-item" open>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ) : null}
        <article class="faq-item">
          <h3>Đặt lịch tư vấn</h3>
          <p>{clinicSite.name} ưu tiên giải thích rõ phạm vi và kỳ vọng trước khi người dùng quyết định bước tiếp theo.</p>
          <a class="button button-primary" href="/lien-he">Đi tới trang liên hệ</a>
        </article>
      </div>
    </article>
  </section>
</ClinicLayout>
