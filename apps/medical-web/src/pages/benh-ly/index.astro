---
import ClinicLayout from "../../layouts/ClinicLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { clinicSite, articleCards, faqItems } from "../../data/site";
import { conditionPages } from "../../data/seo";
import "../../styles/global.css";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: "https://taitaoantam.vn/" },
      { "@type": "ListItem", position: 2, name: "Bệnh lý", item: "https://taitaoantam.vn/benh-ly/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Cụm chủ đề bệnh lý",
    itemListElement: conditionPages.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      url: `https://taitaoantam.vn/benh-ly/${item.slug}/`
    }))
  }
];
---

<ClinicLayout
  title={`${clinicSite.name} | Bệnh lý`}
  description="Cụm chủ đề bệnh lý và triệu chứng thường được người dùng tìm hiểu trước khi đặt lịch tư vấn"
  activeHref="/faq"
  structuredData={structuredData}
>
  <section class="page-hero page-hero-slim">
    <div class="hero-copy">
      <p class="eyebrow">Bệnh lý / pSEO</p>
      <h1>Cụm bệnh lý và triệu chứng người dùng thường tìm trước khi tư vấn</h1>
      <p class="hero-text">
        Đây là trang hub để gom các truy vấn có ý định tìm hiểu bệnh lý, triệu chứng và thời điểm nên gặp bác sĩ thay vì chỉ đọc nội dung rời
        rạc trên blog.
      </p>
    </div>
    <div class="hero-visual hero-visual-note">
      <h2>Mục tiêu của hub</h2>
      <ul>
        <li>Làm rõ nhu cầu tìm kiếm của người đọc</li>
        <li>Gắn sang bài viết, FAQ và hồ sơ bác sĩ</li>
        <li>Giữ nội dung an toàn, không thay thế chẩn đoán</li>
        <li>Tạo cấu trúc topic cluster rõ hơn cho Google</li>
      </ul>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Triệu chứng và bối cảnh" title="Các chủ đề bệnh lý nên có trong bản đầu" />
    <div class="service-grid">
      {conditionPages.map((item) => (
        <article class="feature-card">
          <p class="doctor-eyebrow">{item.keyword}</p>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <p class="article-credit">{item.overview}</p>
          <ul class="mini-list">
            {item.signs.map((sign) => <li>{sign}</li>)}
          </ul>
          <a class="button button-primary" href={`/benh-ly/${item.slug}`}>Xem trang chi tiết</a>
        </article>
      ))}
    </div>
  </section>

  <section class="split-grid">
    <article class="section-block">
      <SectionHeading eyebrow="Bài viết liên quan" title="Bài viết nên được gắn từ hub bệnh lý" />
      <div class="faq-list">
        {articleCards.map((article) => (
          <article class="faq-item">
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <small class="article-credit">Intent: {article.primaryIntent} · Duyệt: {article.reviewer}</small>
          </article>
        ))}
      </div>
    </article>

    <article class="section-block">
      <SectionHeading eyebrow="FAQ" title="Câu hỏi hỗ trợ quyết định" />
      <div class="faq-list">
        {faqItems.slice(0, 4).map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.shortAnswer}</p>
            <small class="faq-reviewed">Cập nhật: {item.lastReviewedAt}</small>
          </details>
        ))}
      </div>
    </article>
  </section>
</ClinicLayout>
