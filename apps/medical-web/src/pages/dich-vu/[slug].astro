---
import ClinicLayout from "../../layouts/ClinicLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { articleCards, clinicSite, doctors, faqItems, processSteps } from "../../data/site";
import { servicePages } from "../../data/seo";
import "../../styles/global.css";

export function getStaticPaths() {
  return servicePages.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const doctor = doctors.find((entry) => entry.slug === item.doctorSlug);
const article = articleCards.find((entry) => entry.slug === item.articleSlug);
const faq = faqItems.find((entry) => entry.slug === item.faqSlug);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Trang chủ", item: "https://taitaoantam.vn/" },
      { "@type": "ListItem", position: 2, name: "Dịch vụ", item: "https://taitaoantam.vn/dich-vu/" },
      { "@type": "ListItem", position: 3, name: item.title, item: `https://taitaoantam.vn/dich-vu/${item.slug}/` }
    ]
  }
];
---

<ClinicLayout
  title={`${item.title} | Dịch vụ`}
  description={item.description}
  canonical={`https://taitaoantam.vn/dich-vu/${item.slug}/`}
  structuredData={structuredData}
  activeHref="/phuong-phap-dieu-tri"
>
  <section class="article-hero">
    <div>
      <p class="eyebrow">Dịch vụ / {item.keyword}</p>
      <h1>{item.title}</h1>
      <p>{item.description}</p>
      <div class="inline-tags">
        <span class="tag-pill">{item.keyword}</span>
        {doctor ? <span class="tag-pill">Bác sĩ: {doctor.name}</span> : null}
        {article ? <span class="tag-pill">Bài viết: {article.title}</span> : null}
      </div>
    </div>
    <article class="page-card article-body">
      <SectionHeading eyebrow="Tổng quan" title="Trang dịch vụ này nên giải thích gì?" />
      <p>{item.overview}</p>
      <p class="notice notice-soft">Mục tiêu là giúp người đọc hiểu rõ dịch vụ, quy trình và bước tiếp theo, thay vì chỉ đưa ra một form liên hệ trống.</p>
    </article>
  </section>

  <section class="split-grid">
    <article class="section-block">
      <SectionHeading eyebrow="Quy trình" title="Trang dịch vụ nên gắn với bước nào?" />
      <div class="process-grid process-grid-full">
        {processSteps.map((step, index) => (
          <article class="process-card">
            <div class="step-number">{index + 1}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </article>

    <article class="section-block">
      <SectionHeading eyebrow="Liên kết nội bộ" title="Trang nên được nối sang đâu?" />
      <div class="faq-list">
        {doctor ? (
          <article class="faq-item">
            <h3>Hồ sơ bác sĩ phụ trách</h3>
            <p>{doctor.profileFocus}</p>
            <a class="button button-secondary" href={`/bac-si/${doctor.slug}`}>Xem hồ sơ</a>
          </article>
        ) : null}
        {article ? (
          <article class="faq-item">
            <h3>Bài viết liên quan</h3>
            <p>{article.description}</p>
            <a class="button button-secondary" href={`/blog/${article.slug}`}>Đọc bài viết</a>
          </article>
        ) : null}
        {faq ? (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ) : null}
      </div>
    </article>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="CTA" title="Nếu phù hợp, hãy đặt lịch tư vấn" />
    <p>{clinicSite.name} luôn ưu tiên giải thích rõ phạm vi, kỳ vọng và bước tiếp theo trước khi người dùng quyết định.</p>
    <a class="button button-primary" href="/lien-he">Đặt lịch tư vấn</a>
  </section>
</ClinicLayout>
