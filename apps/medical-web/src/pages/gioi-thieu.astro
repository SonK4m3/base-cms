---
import ClinicLayout from "../layouts/ClinicLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { clinicSite, complianceCards } from "../data/site";
import "../styles/global.css";

const heroImage = "/assets/contact-hero-reception.png";
const ctaImage = "/assets/hero-tao-an-tam.png";

const valueCards = [
  {
    title: "Tầm nhìn",
    description:
      "Trở thành phòng khám tiên phong và đáng tin cậy hàng đầu tại Việt Nam trong lĩnh vực tư vấn sức khỏe tái tạo."
  },
  {
    title: "Sứ mệnh",
    description:
      "Ứng dụng khoa học y tế để hỗ trợ phục hồi và nâng cao chất lượng sống, với sự an toàn, minh bạch và cá nhân hóa."
  },
  {
    title: "Giá trị cốt lõi",
    description: "An toàn, minh bạch, khoa học, tôn trọng cá nhân hóa và bảo mật thông tin."
  }
];

const introStats = [
  { label: "Tư vấn chuyên sâu 1:1", value: "Phác đồ cá nhân hóa" },
  { label: "Kinh nghiệm", value: "10+ năm" },
  { label: "Khách hàng tin tưởng", value: "5.000+" },
  { label: "Nguyên tắc hoạt động", value: "Minh bạch" }
];

const featureCards = [
  "Minh bạch chuyên môn",
  "Bác sĩ rõ hồ sơ",
  "Quy trình rõ ràng",
  "Bảo mật thông tin",
  "Theo dõi sau tư vấn",
  "Trải nghiệm toàn diện"
];

const facilityCards = [
  { title: "Khu vực lễ tân", position: "20% 58%" },
  { title: "Phòng tư vấn 1:1", position: "50% 46%" },
  { title: "Thiết bị hiện đại", position: "74% 54%" },
  { title: "Khu vực chờ", position: "50% 72%" }
];

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Trang chủ", item: "https://taitaoantam.vn/" },
    { "@type": "ListItem", position: 2, name: "Giới thiệu", item: "https://taitaoantam.vn/gioi-thieu/" }
  ]
};
---

<ClinicLayout
  title={`${clinicSite.name} | Giới thiệu`}
  description="Thông tin giới thiệu, định hướng chuyên môn và pháp lý"
  activeHref="/gioi-thieu"
  structuredData={breadcrumbStructuredData}
>
  <section class="page-hero page-hero-slim">
    <div class="hero-copy">
      <p class="eyebrow">Giới thiệu</p>
      <h1>Phòng khám Tái Tạo An Tâm</h1>
      <p class="hero-text">
        Chúng tôi tin rằng mỗi tế bào khỏe mạnh là khởi đầu cho một cơ thể khỏe mạnh và cuộc sống chất lượng. Phòng khám Tái Tạo An Tâm
        đồng hành cùng bạn bằng y học tái tạo hiện đại, an toàn và minh bạch.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/lien-he">Đặt lịch tư vấn</a>
        <a class="button button-secondary" href="/phuong-phap-dieu-tri">Tìm hiểu dịch vụ</a>
      </div>
    </div>

    <div class="hero-visual hero-visual-large">
      <img src={heroImage} alt="Khu vực lễ tân Phòng khám Tái Tạo An Tâm" />
    </div>
  </section>

  <section class="section-block">
    <SectionHeading title="Tầm nhìn - Sứ mệnh - Giá trị cốt lõi" align="center" />
    <div class="card-grid value-grid">
      {valueCards.map((card) => (
        <article class="info-card info-card-center value-card">
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <SectionHeading
      eyebrow="Về phòng khám"
      title="Về phòng khám"
      description="Phòng khám Tái Tạo An Tâm định hướng chuyên sâu trong lĩnh vực y học tái tạo và tư vấn tế bào gốc."
    />
    <div class="about-grid">
      <article class="page-card about-copy">
        <p>
          Chúng tôi tập trung vào tư vấn, đánh giá và đưa ra giải pháp phù hợp dựa trên tình trạng sức khỏe của từng khách hàng, dựa trên
          bằng chứng khoa học và các công nghệ hiện đại.
        </p>
        <p>
          Với đội ngũ bác sĩ giàu kinh nghiệm, quy trình chuẩn hóa và hệ thống cơ sở vật chất hiện đại, chúng tôi cam kết mang đến trải nghiệm
          chăm sóc chuyên nghiệp, an toàn và hiệu quả.
        </p>
      </article>

      <article class="stats-panel">
        {introStats.map((item) => (
          <div class="stats-item">
            <div class="stats-value">{item.value}</div>
            <div class="stats-label">{item.label}</div>
          </div>
        ))}
      </article>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Điểm nổi bật" title="Điểm nổi bật của phòng khám" />
    <div class="card-grid feature-grid">
      {featureCards.map((item) => (
        <article class="feature-card feature-card-compact">
          <h3>{item}</h3>
          <p>Tư vấn tập trung vào an toàn, hiểu đúng và cá nhân hóa theo từng nhu cầu.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Cơ sở vật chất" title="Cơ sở vật chất" align="center" />
    <div class="facility-grid">
      {facilityCards.map((item) => (
        <figure class="facility-card">
          <img src={heroImage} alt={item.title} style={`object-position: ${item.position};`} />
          <figcaption>{item.title}</figcaption>
        </figure>
      ))}
    </div>
    <div class="facility-dots" aria-hidden="true">
      <span class="is-active"></span>
      <span></span>
      <span></span>
      <span></span>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading eyebrow="Định hướng" title="Định hướng chuyên môn và pháp lý" />
    <div class="card-grid compliance-grid compliance-grid-contact">
      {complianceCards.map((card) => (
        <article class="info-card">
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="contact-cta section-block">
    <div class="cta-copy">
      <div class="cta-portrait">
        <img src={ctaImage} alt="Bác sĩ tư vấn" />
      </div>
      <div>
        <h2>Bạn cần tư vấn?</h2>
        <p>Đội ngũ bác sĩ của chúng tôi luôn sẵn sàng đồng hành cùng bạn.</p>
      </div>
      <div class="cta-benefits">
        <div>Tư vấn chuyên sâu 1:1</div>
        <div>Đặt lịch nhanh chóng</div>
        <div>Bảo mật thông tin</div>
      </div>
      <a class="hotline-box hotline-link" href="tel:1900123456">1900 1234 56</a>
    </div>

    <div class="contact-cta-form">
      <p class="eyebrow">Liên hệ</p>
      <h2>Đặt lịch tư vấn ngay</h2>
      <p>Chọn thời gian phù hợp và để phòng khám chủ động liên hệ lại cho bạn.</p>
      <div class="faq-side-list">
        <a href="/bac-si">Đội ngũ bác sĩ</a>
        <a href="/faq">Câu hỏi thường gặp</a>
        <a href="/blog">Blog kiến thức</a>
        <a href="/nghien-cuu-cong-bo">Nghiên cứu & công bố</a>
      </div>
      <a class="button button-primary" href="/lien-he">Mở form liên hệ</a>
    </div>
  </section>
</ClinicLayout>
