---
import NotexLayout from "../../layouts/NotexLayout.astro";
import { notexCustomers, notexSite } from "../../data/notex";
import { createBreadcrumbSchema } from "@base-cms/site-core";
export function getStaticPaths() { return notexCustomers.map((item) => ({ params: { slug: item.slug }, props: { item } })); }
const { item } = Astro.props;
const schema = { "@type": "Article", headline: item.title, description: item.summary, author: { "@type": "Organization", name: item.name } };
const breadcrumbs = createBreadcrumbSchema([{ name: "Notex", url: notexSite.url }, { name: "Customers", url: `${notexSite.url}customers/` }, { name: item.name, url: `${notexSite.url}customers/${item.slug}/` }]);
---
<NotexLayout title={`${item.title} | Notex customer story`} description={item.summary} canonical={`/customers/${item.slug}/`} structuredData={[schema, breadcrumbs]}>
  <section class="notex-page-hero"><div class="notex-container"><p class="notex-breadcrumb"><a href="/customers/">Customers</a> / {item.name}</p><p class="notex-eyebrow">{item.name} · {item.industry}</p><h1>{item.title}</h1><p>{item.summary}</p></div></section>
  <section class="notex-section"><div class="notex-container"><div class="notex-index-grid">{item.metrics.map((metric) => <div class="notex-index-card"><span>Outcome</span><h3>{metric}</h3><p>Measured against the team's workflow before adopting a shared context layer.</p></div>)}</div></div></section>
</NotexLayout>
