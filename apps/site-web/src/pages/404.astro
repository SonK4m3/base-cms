---
import SiteLayout from "../layouts/SiteLayout.astro";
import { buildJsonLdGraph, buildMetadata } from "@base-cms/site-core";
import { siteContext } from "../data/site.ts";
const metadata = buildMetadata(siteContext, { title: "Page not found", description: "The requested page could not be found.", path: "/404/", robots: "noindex,nofollow" });
const graph = buildJsonLdGraph(siteContext, metadata);
---
<SiteLayout metadata={metadata} graph={graph}>
  <section class="hero"><div class="container narrow"><p class="eyebrow">404</p><h1>Page not found</h1><p class="summary">The page may have moved, been retired, or never existed.</p><a class="button" href="/">Return home</a></div></section>
</SiteLayout>
