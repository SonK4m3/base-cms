{
  "kind": "collection-type",
  "collectionName": "authors",
  "info": { "singularName": "author", "pluralName": "authors", "displayName": "Author", "description": "Reusable author, reviewer, or subject expert profile" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "jobTitle": { "type": "string" },
    "summary": { "type": "text", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "bio": { "type": "richtext", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "image": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "expertise": { "type": "json", "default": [] },
    "credentials": { "type": "json", "default": [] },
    "sameAs": { "type": "json", "default": [] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "editorial": { "type": "component", "repeatable": false, "required": true, "component": "shared.editorial-control" }
  }
}
