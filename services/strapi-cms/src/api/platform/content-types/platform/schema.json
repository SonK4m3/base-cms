{
  "kind": "collection-type",
  "collectionName": "platforms",
  "info": { "singularName": "platform", "pluralName": "platforms", "displayName": "Platform", "description": "Product line, ecosystem, platform, or business unit" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "externalId": { "type": "string", "unique": true },
    "name": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "slug": { "type": "uid", "targetField": "name", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "description": { "type": "richtext", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "audience": { "type": "text", "required": true },
    "capabilities": { "type": "json", "default": [] },
    "compatibility": { "type": "richtext" },
    "products": { "type": "relation", "relation": "manyToMany", "target": "api::product.product" },
    "services": { "type": "relation", "relation": "manyToMany", "target": "api::service.service" },
    "documentation": { "type": "component", "repeatable": true, "component": "catalog.document" },
    "relatedPlatforms": { "type": "relation", "relation": "manyToMany", "target": "api::platform.platform" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "editorial": { "type": "component", "repeatable": false, "required": true, "component": "shared.editorial-control" },
    "importedAt": { "type": "datetime" },
    "sourceChecksum": { "type": "string", "private": true }
  }
}
