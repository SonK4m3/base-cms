{
  "kind": "collection-type",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "Doctor",
    "description": "Doctor profile and credentials"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "specialty": {
      "type": "string"
    },
    "bio": {
      "type": "richtext"
    },
    "credentials": {
      "type": "json",
      "default": []
    },
    "languages": {
      "type": "json",
      "default": []
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}

