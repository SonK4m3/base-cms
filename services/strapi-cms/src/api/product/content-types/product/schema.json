{
  "kind": "collection-type",
  "collectionName": "products",
  "info": { "singularName": "product", "pluralName": "products", "displayName": "Product", "description": "Non-transactional catalog product" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "externalId": { "type": "string", "required": true, "unique": true },
    "sku": { "type": "string", "unique": true },
    "name": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "slug": { "type": "uid", "targetField": "name", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "description": { "type": "richtext", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "productType": { "type": "string" },
    "brand": { "type": "relation", "relation": "manyToOne", "target": "api::brand.brand" },
    "categories": { "type": "relation", "relation": "manyToMany", "target": "api::category.category" },
    "platforms": { "type": "relation", "relation": "manyToMany", "target": "api::platform.platform" },
    "specifications": { "type": "component", "repeatable": true, "component": "catalog.specification" },
    "applications": { "type": "json", "default": [] },
    "gallery": { "type": "media", "multiple": true, "allowedTypes": ["images"] },
    "galleryAlt": { "type": "json", "default": [] },
    "documents": { "type": "component", "repeatable": true, "component": "catalog.document" },
    "displayVariants": { "type": "json", "default": [] },
    "priceDisplay": { "type": "decimal" },
    "currency": { "type": "string" },
    "availability": { "type": "enumeration", "enum": ["available", "temporarily_unavailable", "discontinued", "contact"], "default": "contact", "required": true },
    "replacementProduct": { "type": "relation", "relation": "oneToOne", "target": "api::product.product" },
    "retainSeoValue": { "type": "boolean", "default": false },
    "warrantySupport": { "type": "richtext" },
    "relatedProducts": { "type": "relation", "relation": "manyToMany", "target": "api::product.product" },
    "leadFormType": { "type": "enumeration", "enum": ["product_inquiry", "request_quote"], "default": "product_inquiry" },
    "claims": { "type": "relation", "relation": "manyToMany", "target": "api::claim-evidence.claim-evidence" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "editorial": { "type": "component", "repeatable": false, "required": true, "component": "shared.editorial-control" },
    "importedAt": { "type": "datetime" },
    "sourceChecksum": { "type": "string", "private": true }
  }
}
