{
  "kind": "collection-type",
  "collectionName": "medical_conditions",
  "info": {
    "singularName": "medical-condition",
    "pluralName": "medical-conditions",
    "displayName": "Medical condition",
    "description": "Symptom or condition landing page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq-item"
    },
    "relatedServices": {
      "type": "json",
      "default": []
    },
    "relatedArticles": {
      "type": "json",
      "default": []
    }
  }
}

