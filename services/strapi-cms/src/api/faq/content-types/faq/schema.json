{
  "kind": "collection-type",
  "collectionName": "faqs",
  "info": { "singularName": "faq", "pluralName": "faqs", "displayName": "FAQ", "description": "Reusable visible question and answer" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "question": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "answer": { "type": "richtext", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "topic": { "type": "string" },
    "sourceReferences": { "type": "component", "repeatable": true, "component": "shared.reference" },
    "editorial": { "type": "component", "repeatable": false, "required": true, "component": "shared.editorial-control" }
  }
}
