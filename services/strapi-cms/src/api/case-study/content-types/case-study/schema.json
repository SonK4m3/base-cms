{
  "kind": "collection-type",
  "collectionName": "case_studies",
  "info": { "singularName": "case-study", "pluralName": "case-studies", "displayName": "Case study", "description": "Evidence-backed customer or project case study" },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "slug": { "type": "uid", "targetField": "title", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "customerDisplayName": { "type": "string" },
    "challenge": { "type": "richtext", "required": true },
    "approach": { "type": "richtext", "required": true },
    "outcomes": { "type": "richtext", "required": true },
    "author": { "type": "relation", "relation": "manyToOne", "target": "api::author.author" },
    "reviewer": { "type": "relation", "relation": "manyToOne", "target": "api::author.author" },
    "evidence": { "type": "relation", "relation": "manyToMany", "target": "api::claim-evidence.claim-evidence" },
    "consentConfirmed": { "type": "boolean", "default": false, "private": true },
    "relatedEntryIds": { "type": "json", "default": [] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "editorial": { "type": "component", "repeatable": false, "required": true, "component": "shared.editorial-control" }
  }
}
