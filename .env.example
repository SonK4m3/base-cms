# Public site
PUBLIC_SITE_URL=https://taitaoantam.vn
PUBLIC_STRAPI_URL=https://cms.taitaoantam.vn
PUBLIC_CMS_URL=https://cms.taitaoantam.vn
PUBLIC_SITE_DOMAIN=taitaoantam.vn
PUBLIC_CMS_DOMAIN=cms.taitaoantam.vn
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXX
PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# Astro build/runtime
NODE_ENV=production

# Strapi app
HOST=0.0.0.0
PORT=1337
CMS_SEED_DEMO_CONTENT=true
APP_KEYS=replace-with-2-keys
API_TOKEN_SALT=replace-with-a-long-random-string
ADMIN_JWT_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=base_cms
DATABASE_USERNAME=base_cms
DATABASE_PASSWORD=base_cms

# Postgres container
POSTGRES_DB=base_cms
POSTGRES_USER=base_cms
POSTGRES_PASSWORD=base_cms

# Optional Caddy
CADDY_EMAIL=admin@example.com

# Pages Functions / integrations
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
CMS_READ_TOKEN=replace-with-cms-read-token
RESEND_API_KEY=replace-with-resend-api-key
