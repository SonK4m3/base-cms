# Select exactly one dedicated website deployment
SITE_ID=customer-site-id
SITE_CONFIG_PATH=sites/customer-site-id/site.config.json
PUBLIC_SITE_URL=https://www.customer-domain.com
ENFORCE_PRODUCTION_GATES=true
PREVIEW_NOINDEX=false

# Dedicated Strapi source (never expose tokens with PUBLIC_ prefixes)
STRAPI_URL=https://cms.customer-domain.com
STRAPI_READ_TOKEN=replace-with-read-token
STRAPI_WRITE_TOKEN=replace-with-write-token
CATALOG_IMAGE_HOSTS=media.customer-domain.com

# Public analytics and crawler integrations for this domain only
PUBLIC_GA4_ID=G-XXXXXXXXXX
INDEXNOW_KEY=replace-with-site-specific-indexnow-key
PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# Strapi runtime
HOST=0.0.0.0
PORT=1337
APP_KEYS=replace-with-comma-separated-random-keys
API_TOKEN_SALT=replace-with-a-long-random-string
ADMIN_JWT_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# Dedicated PostgreSQL
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=customer_site_cms
DATABASE_USERNAME=customer_site_cms
DATABASE_PASSWORD=replace-with-unique-database-password
POSTGRES_DB=customer_site_cms
POSTGRES_USER=customer_site_cms
POSTGRES_PASSWORD=replace-with-unique-database-password

# Lead delivery and abuse controls
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
LEAD_EMAIL_WEBHOOK=replace-with-site-specific-webhook

# Deployment
CLOUDFLARE_PAGES_PROJECT_NAME=customer-site-id
CF_PAGES_BRANCH=main
PUBLIC_SITE_DOMAIN=www.customer-domain.com
PUBLIC_CMS_DOMAIN=cms.customer-domain.com
CADDY_EMAIL=admin@customer-domain.com
